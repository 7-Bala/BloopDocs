{
  "name": "bloopdocs",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "ELECTRON_BUILD=true npm run build && electron .",
    "electron:build": "ELECTRON_BUILD=true npm run build && electron-builder --mac --win"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "docx": "^9.7.1",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.think2thrive.bloopdocs",
    "productName": "BloopDocs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "out/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    }
  }
}
